# Application
APP_NAME=Transaction Ranking System
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/transaction_ranking

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Security
API_KEY_HEADER=X-API-Key
MAX_TRANSACTION_AMOUNT=1000000

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Abuse prevention
MAX_TRANSACTIONS_PER_MINUTE=10
DUPLICATE_CHECK_WINDOW=300

# Ranking weights
POINTS_WEIGHT=0.6
ACTIVITY_WEIGHT=20.0
CONSISTENCY_WEIGHT=20.0
